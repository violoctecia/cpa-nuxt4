{
	"semi": true,
	"singleQuote": true,
	"trailingComma": "all",
	"bracketSpacing": true,
	"printWidth": 130,
	"useTabs": true,
	"tabWidth": 4,
	"endOfLine": "auto",
	"arrowParens": "always",
	"embeddedLanguageFormatting": "auto",
	"plugins": ["prettier-plugin-organize-imports"],
	"htmlWhitespaceSensitivity": "ignore",
	"singleAttributePerLine": true
}